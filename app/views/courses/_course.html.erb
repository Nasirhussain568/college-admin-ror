<div id="<%= dom_id course %>">
  <p>
    <strong>Title:</strong>
    <%= course.title %>
  </p>

  <p>
    <strong>Course code:</strong>
    <%= course.course_code %>
  </p>

  <p>
    <strong>Credits:</strong>
    <%= course.credits %>
  </p>

  <p>
    <strong>Department:</strong>
    <%= course.department_id %>
  </p>

</div>
